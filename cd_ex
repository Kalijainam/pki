mkdir ssl-lab
cd ssl-lab

openssl genpkey -algorithm RSA -out root.key

openssl req -new -key root.key -out root.csr

cat > root.ext << EOF
basicConstraints=critical,CA:TRUE
keyUsage=critical,keyCertSign,cRLSign
subjectKeyIdentifier=hash
authorityKeyIdentifier=keyid:always,issuer
EOF

openssl x509 -req -in root.csr -signkey root.key -out root.crt -days 3650 -extfile root.ext

openssl genpkey -algorithm RSA -out sub.key

openssl req -new -key sub.key -out sub.csr

cat > sub.ext << EOF
basicConstraints=critical,CA:TRUE,pathlen:0
keyUsage=critical,keyCertSign,cRLSign
subjectKeyIdentifier=hash
authorityKeyIdentifier=keyid,issuer
EOF

openssl x509 -req -in sub.csr -CA root.crt -CAkey root.key -CAcreateserial -out sub.crt -days 1825 -extfile sub.ext

openssl genpkey -algorithm RSA -out server.key

openssl req -new -key server.key -out server.csr

cat > server.ext << EOF
basicConstraints=CA:FALSE
keyUsage=digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth
subjectAltName=DNS:example.com,DNS:localhost
EOF

openssl x509 -req -in server.csr -CA sub.crt -CAkey sub.key -CAcreateserial -out server.crt -days 365 -extfile server.ext

openssl verify -CAfile root.crt -untrusted sub.crt server.crt

sudo apt update

sudo apt install apache2 openssl -y

sudo a2enmod ssl

sudo mkdir -p /etc/apache2/ssl

sudo cp server.crt /etc/apache2/ssl/

sudo cp server.key /etc/apache2/ssl/

sudo cp sub.crt /etc/apache2/ssl/

echo "<h1>HTTPS Enabled Successfully</h1>" | sudo tee /var/www/html/index.html

echo "127.0.0.1 example.com" | sudo tee -a /etc/hosts

sudo tee /etc/apache2/sites-available/ssl.conf > /dev/null << EOF
<VirtualHost *:443>

    ServerName example.com

    DocumentRoot /var/www/html

    SSLEngine on

    SSLCertificateFile /etc/apache2/ssl/server.crt

    SSLCertificateKeyFile /etc/apache2/ssl/server.key

    SSLCertificateChainFile /etc/apache2/ssl/sub.crt

</VirtualHost>
EOF

sudo a2ensite ssl.conf

echo "ServerName localhost" | sudo tee -a /etc/apache2/apache2.conf

sudo apachectl configtest

sudo systemctl restart apache2

sudo systemctl status apache2

sudo ss -tulpn | grep 443

curl -k https://example.com
